---
import '../styles/site.css';
const site = {
  name: 'Woodside Kennels & Cattery',
  phone: '01832 720623',
  address: '1 Clopton, Kettering, Northants NN14 3DZ',
};
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Woodside Kennels & Cattery | Pet Boarding in Kettering</title>
  <meta name="description" content="Superior boarding for cats and dogs in the Northamptonshire countryside. Heated kennels, UPVC chalets, four grass paddocks and daily countryside walks." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- Preview Banner -->
  <div style="background:#B45309;color:white;padding:10px 16px;text-align:center;font-size:14px;position:sticky;top:0;z-index:50"><div style="max-width:56rem;margin:0 auto;display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap"><span>Preview redesign for <strong>Woodside Kennels & Cattery</strong></span><a href="https://biscuitweb.co.uk/activate?id=P2503&amp;name=Woodside%20Kennels%20%26%20Cattery" style="display:inline-flex;align-items:center;padding:4px 16px;background:white;color:#B45309;font-weight:700;font-size:12px;border-radius:9999px;text-decoration:none">Like it? Just £20/month</a></div></div>

  <!-- Nav -->
  <nav class="bg-[var(--color-brand-accent-deep)] text-white sticky top-[45px] z-40">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href="/P2503" class="font-display font-800 text-lg text-white hover:text-[var(--color-accent-light)] transition-colors">
        Woodside Kennels &amp; Cattery
      </a>
      <!-- Desktop nav -->
      <ul class="hidden md:flex gap-8 text-sm font-semibold">
        <li><a href="/P2503" class="text-white hover:text-[var(--color-accent-light)] transition-colors">Home</a></li>
        <li><a href="/P2503/cats-html" class="text-white hover:text-[var(--color-accent-light)] transition-colors">Cats</a></li>
        <li><a href="/P2503/dogs-html" class="text-white hover:text-[var(--color-accent-light)] transition-colors">Dogs</a></li>
        <li><a href="/P2503/contact-html" class="text-white hover:text-[var(--color-accent-light)] transition-colors">Contact</a></li>
      </ul>
      <!-- Hamburger -->
      <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu" aria-expanded="false">
        <span class="block w-6 h-0.5 bg-white transition-all" id="bar1"></span>
        <span class="block w-6 h-0.5 bg-white transition-all" id="bar2"></span>
        <span class="block w-6 h-0.5 bg-white transition-all" id="bar3"></span>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-[var(--color-brand-accent-deep)] border-t border-white/20 px-4 pb-4">
      <ul class="flex flex-col gap-3 pt-3 text-sm font-semibold">
        <li><a href="/P2503" class="block text-white hover:text-[var(--color-accent-light)] transition-colors py-1">Home</a></li>
        <li><a href="/P2503/cats-html" class="block text-white hover:text-[var(--color-accent-light)] transition-colors py-1">Cats</a></li>
        <li><a href="/P2503/dogs-html" class="block text-white hover:text-[var(--color-accent-light)] transition-colors py-1">Dogs</a></li>
        <li><a href="/P2503/contact-html" class="block text-white hover:text-[var(--color-accent-light)] transition-colors py-1">Contact</a></li>
      </ul>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative overflow-hidden min-h-[90vh] flex items-center">
    <img
      src="/P2503/images/layout-top.jpg"
      alt="Woodside Kennels and Cattery countryside setting"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 py-24 text-center text-white">
      <span class="inline-block bg-[var(--color-brand-accent)] text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-6">📍 Kettering, Northamptonshire</span>
      <h1 class="text-4xl md:text-6xl font-800 leading-tight mb-6 text-white">
        Woodside Kennels<br />&amp; Cattery
      </h1>
      <p class="text-xl md:text-2xl text-white/90 mb-10 max-w-2xl mx-auto">
        Superior boarding for your cats and dogs in the beautiful Northamptonshire countryside
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/P2503/contact-html" class="inline-block bg-[var(--color-brand-accent)] hover:bg-[var(--color-brand-accent-deep)] text-white font-700 px-8 py-3 rounded-lg transition-colors">
          Get in Touch
        </a>
        <a href="tel:01832720623" class="inline-block bg-white/20 hover:bg-white/30 text-white font-700 px-8 py-3 rounded-lg transition-colors border border-white/40">
          Call 01832 720623
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="bg-[var(--color-brand-accent)] text-white py-8">
    <div class="max-w-6xl mx-auto px-6">
      <ul class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <li>
          <div class="text-3xl mb-2">🌿</div>
          <div class="font-700 text-sm">Countryside Setting</div>
          <div class="text-white/80 text-xs mt-1">Just off the A604, Northants</div>
        </li>
        <li>
          <div class="text-3xl mb-2">🏠</div>
          <div class="font-700 text-sm">Superior Accommodation</div>
          <div class="text-white/80 text-xs mt-1">Heated, spacious &amp; hygienic</div>
        </li>
        <li>
          <div class="text-3xl mb-2">🛡️</div>
          <div class="font-700 text-sm">Fully Insured</div>
          <div class="text-white/80 text-xs mt-1">Comprehensive cover included</div>
        </li>
        <li>
          <div class="text-3xl mb-2">👁️</div>
          <div class="font-700 text-sm">Viewings Welcome</div>
          <div class="text-white/80 text-xs mt-1">Come and see for yourself</div>
        </li>
      </ul>
    </div>
  </section>

  <!-- About / Main Content -->
  <section class="py-20 bg-[var(--color-brand-bg)]">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-800 text-[var(--color-ink)] mb-4">A home from home for your pet</h2>
        <p class="text-[var(--color-ink-soft)] text-lg max-w-2xl mx-auto">
          Woodside Pet Hotel is situated in the beautiful Northamptonshire countryside just off the A604 between Thrapston and Oundle.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-[var(--color-ink-soft)] text-base leading-relaxed mb-6">
            We offer superior accommodation for cats and dogs. You can relax in the knowledge that your pet will enjoy first class care in a safe, happy and comfortable environment.
          </p>
          <p class="text-[var(--color-ink-soft)] text-base leading-relaxed mb-6">
            Cleanliness is a top priority with each chalet thoroughly cleaned every day using high quality veterinary virucidal disinfectant.
          </p>
          <p class="text-[var(--color-ink-soft)] text-base leading-relaxed">
            Fully comprehensive insurance is included for the duration of your pet's stay and viewing is encouraged for all owners.
          </p>
        </div>
        <div class="bg-[var(--color-cream)] rounded-2xl p-8 border border-[var(--color-border)]">
          <h3 class="text-xl font-700 text-[var(--color-ink)] mb-6">Our Facilities</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-[var(--color-brand-accent)] font-700 text-lg mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)]">Four grass paddocks for daily exercise and play</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[var(--color-brand-accent)] font-700 text-lg mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)]">Daily off-road walk (on extended lead) through woodland and natural countryside</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[var(--color-brand-accent)] font-700 text-lg mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)]">Heated, climate-controlled sleeping quarters</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[var(--color-brand-accent)] font-700 text-lg mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)]">Veterinary virucidal disinfectant used daily</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[var(--color-brand-accent)] font-700 text-lg mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)]">Fully comprehensive insurance included</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[var(--color-brand-accent)] font-700 text-lg mt-0.5">✓</span>
              <span class="text-[var(--color-ink-soft)]">Medication administered at no extra charge</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-[var(--color-cream)]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-800 text-[var(--color-ink)] mb-4">What We Offer</h2>
        <p class="text-[var(--color-ink-soft)] max-w-xl mx-auto">Whether you have cats or dogs, we have the perfect boarding solution in the Northamptonshire countryside.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <a href="/P2503/cats-html" class="group block bg-white rounded-2xl overflow-hidden border border-[var(--color-border)] hover:shadow-lg transition-shadow">
          <div class="aspect-video overflow-hidden">
            <img
              src="/P2503/images/cats3.jpg"
              alt="Cat cattery chalets at Woodside"
              width="600"
              height="338"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-800 text-[var(--color-ink)] mb-3">Cat Boarding</h3>
            <p class="text-[var(--color-ink-soft)] mb-4">Modern UPVC chalets with double glazing, climate control and individual furnishings including scratch tree, chair, litter tray and sleeping basket.</p>
            <span class="text-[var(--color-brand-accent)] font-700 text-sm">Find out more &rarr;</span>
          </div>
        </a>
        <a href="/P2503/dogs-html" class="group block bg-white rounded-2xl overflow-hidden border border-[var(--color-border)] hover:shadow-lg transition-shadow">
          <div class="aspect-video overflow-hidden relative bg-[var(--color-accent-light)]">
            <img
              src="/P2503/images/layout-bottom.jpg"
              alt="Dog kennels at Woodside"
              width="600"
              height="338"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-800 text-[var(--color-ink)] mb-3">Dog Boarding</h3>
            <p class="text-[var(--color-ink-soft)] mb-4">Individually designed kennel block exceeding local authority standards. Heated, spacious sleeping quarters with adjacent covered outdoor areas and four grass paddocks.</p>
            <span class="text-[var(--color-brand-accent)] font-700 text-sm">Find out more &rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden py-24">
    <img
      src="/P2503/images/layout-bottom.jpg"
      alt="Woodside countryside"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 max-w-2xl mx-auto px-6 text-center text-white">
      <h2 class="text-3xl md:text-4xl font-800 mb-4 text-white">Ready to book your pet's stay?</h2>
      <p class="text-white/90 text-lg mb-8">Viewings are always welcome. Give us a call or drop us a message to discuss your requirements.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:01832720623" class="inline-block bg-[var(--color-brand-accent)] hover:bg-[var(--color-brand-accent-deep)] text-white font-700 px-8 py-3 rounded-lg transition-colors">
          Call 01832 720623
        </a>
        <a href="/P2503/contact-html" class="inline-block bg-white/20 hover:bg-white/30 text-white font-700 px-8 py-3 rounded-lg border border-white/40 transition-colors">
          Send a Message
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[var(--color-brand-accent-deep)] text-white pt-12 pb-8">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-10 mb-10">
        <div>
          <h3 class="font-800 text-lg mb-4">Woodside Kennels &amp; Cattery</h3>
          <address class="not-italic text-white/80 text-sm leading-relaxed">
            1 Clopton<br />
            Kettering<br />
            Northants NN14 3DZ
          </address>
          <p class="mt-3 text-white/80 text-sm">
            Tel: <a href="tel:01832720623" class="text-white hover:text-[var(--color-accent-light)] transition-colors">01832 720623</a>
          </p>
        </div>
        <div>
          <h3 class="font-700 text-sm uppercase tracking-wider mb-4 text-white/60">Pages</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/P2503" class="text-white/80 hover:text-white transition-colors">Home</a></li>
            <li><a href="/P2503/cats-html" class="text-white/80 hover:text-white transition-colors">Cat Boarding</a></li>
            <li><a href="/P2503/dogs-html" class="text-white/80 hover:text-white transition-colors">Dog Boarding</a></li>
            <li><a href="/P2503/contact-html" class="text-white/80 hover:text-white transition-colors">Contact Us</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-700 text-sm uppercase tracking-wider mb-4 text-white/60">Location</h3>
          <p class="text-white/80 text-sm leading-relaxed">
            Situated in the beautiful Northamptonshire countryside just off the A604 between Thrapston and Oundle.
          </p>
        </div>
      </div>
      <div class="border-t border-white/20 pt-6 text-center text-xs text-white/50">
        &copy; {new Date().getFullYear()} Woodside Kennels &amp; Cattery. All rights reserved.
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const bar1 = document.getElementById('bar1');
    const bar2 = document.getElementById('bar2');
    const bar3 = document.getElementById('bar3');
    toggle?.addEventListener('click', () => {
      const open = menu?.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (open) {
        bar1?.classList.add('rotate-45', 'translate-y-2');
        bar2?.classList.add('opacity-0');
        bar3?.classList.add('-rotate-45', '-translate-y-2');
      } else {
        bar1?.classList.remove('rotate-45', 'translate-y-2');
        bar2?.classList.remove('opacity-0');
        bar3?.classList.remove('-rotate-45', '-translate-y-2');
      }
    });
  </script>

</body>
</html>
